# =============================================================================
# OmniFile Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=OmniFile Processor
APP_VERSION=2.0.0
APP_ENV=development  # development, staging, production
DEBUG=false
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true  # development only

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400  # 24 hours
JWT_REFRESH_EXPIRATION=604800  # 7 days

API_KEY_HEADER=X-API-Key
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://omnifile:password@localhost:5432/omnifile
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10 MB

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=omnifile
MINIO_SECURE=false

# AWS S3 (alternative)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# -----------------------------------------------------------------------------
# Models
# -----------------------------------------------------------------------------
MODEL_PATH=./models
DEFAULT_OCR_MODEL=trocr-base-printed
DEFAULT_HTR_MODEL=trocr-large-handwritten-arabic

# Hugging Face
HF_TOKEN=  # for private models
HF_CACHE_DIR=./cache

# -----------------------------------------------------------------------------
# Training
# -----------------------------------------------------------------------------
WANDB_API_KEY=
WANDB_PROJECT=omnifile-htr
WANDB_ENTITY=

# Cloud Training
SAGEMAKER_ROLE=
SAGEMAKER_BUCKET=

GOOGLE_CLOUD_PROJECT=
VERTEX_BUCKET=

AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=admin

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Email Notifications
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# -----------------------------------------------------------------------------
# Mobile App
# -----------------------------------------------------------------------------
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000/ws

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_HTR=true
ENABLE_NLP=true
ENABLE_TRANSLATION=false
ENABLE_OFFLINE_MODE=true
ENABLE_REALTIME_COLLAB=true
