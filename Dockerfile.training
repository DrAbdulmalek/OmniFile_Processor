# =============================================================================
# Dockerfile.training — OmniFile Processor Training Environment
# =============================================================================
# بيئة تدريب معزولة مع CUDA 12.1 و PyTorch
#
# أمثلة التشغيل:
#   # بناء الصورة:
#   docker build -f Dockerfile.training -t omnifile-train .
#
#   # تدريب LoRA سريع (اختبار):
#   docker run --gpus all -v $(pwd)/data:/data -v $(pwd)/checkpoints:/checkpoints \
#     omnifile-train python training/train_lora.py --epochs 1 --batch-size 4
#
#   # تدريب كامل:
#   docker run --gpus all -v $(pwd)/data:/data -v $(pwd)/checkpoints:/checkpoints \
#     omnifile-train python training/train_lora.py --epochs 10 --lr 5e-4
#
#   # تدريب Qwen2.5-VL:
#   docker run --gpus all -v $(pwd)/data:/data -v $(pwd)/checkpoints:/checkpoints \
#     omnifile-train python training/train_qwen.py --epochs 5
#
#   # تقييم النموذج:
#   docker run --gpus all -v $(pwd)/data:/data -v $(pwd)/checkpoints:/checkpoints \
#     omnifile-train python -m src.metrics --checkpoint /checkpoints/best
#
#   # تصدير ONNX:
#   docker run --gpus all -v $(pwd)/checkpoints:/checkpoints -v $(pwd)/exports:/exports \
#     omnifile-train python src/export.py --format onnx --checkpoint /checkpoints/best
#
#   # بدء Active Learning:
#   docker run --gpus all -v $(pwd)/data:/data -v $(pwd)/checkpoints:/checkpoints \
#     omnifile-train python -m modules.ai.active_learning --cycle-id test-001
# =============================================================================

FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

LABEL maintainer="OmniFile Processor Team"
LABEL description="Training environment for OmniFile Processor HTR models"
LABEL cuda.version="12.1"

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# System Dependencies
# =============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.10 \
    python3.10-dev \
    python3-pip \
    python3.10-venv \
    git \
    git-lfs \
    curl \
    wget \
    ca-certificates \
    build-essential \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.10 /usr/bin/python \
    && ln -sf /usr/bin/python3.10 /usr/bin/python3

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

# =============================================================================
# PyTorch with CUDA 12.1
# =============================================================================
RUN pip install --no-cache-dir \
    torch==2.3.0 \
    torchvision==0.18.0 \
    torchaudio==2.3.0 \
    --index-url https://download.pytorch.org/whl/cu121

# =============================================================================
# Training Requirements
# =============================================================================
COPY requirements-training.txt /app/requirements-training.txt

RUN pip install --no-cache-dir -r /app/requirements-training.txt

# =============================================================================
# Project Source
# =============================================================================
WORKDIR /app

# Copy source directories
COPY training/ /app/training/
COPY modules/ /app/modules/
COPY src/ /app/src/
COPY mobile_review/ /app/mobile_review/

# Copy configuration and metadata files
COPY config.py /app/config.py
COPY pyproject.toml /app/pyproject.toml

# Set PYTHONPATH so all modules are importable
ENV PYTHONPATH="/app:/app/src:/app/modules:/app/training"

# Create data and checkpoint directories
RUN mkdir -p /app/data /app/checkpoints /app/exports /app/logs

# Volumes for persistent data
VOLUME ["/app/data", "/app/checkpoints", "/app/exports", "/app/logs"]

# =============================================================================
# Health Check & Default Command
# =============================================================================
# Verify PyTorch CUDA is available on startup
RUN python -c "import torch; assert torch.cuda.is_available(), 'CUDA not available!'"

# Default: show help
CMD ["python", "-c", "\
import torch; \
print('=' * 60); \
print('  OmniFile Processor — Training Environment'); \
print('=' * 60); \
print(f'  PyTorch:    {torch.__version__}'); \
print(f'  CUDA:       {torch.version.cuda}'); \
print(f'  GPUs:       {torch.cuda.device_count()}'); \
if torch.cuda.is_available(): \
    print(f'  GPU Name:   {torch.cuda.get_device_name(0)}'); \
    print(f'  GPU Memory: {torch.cuda.get_device_properties(0).total_mem // 1024**3} GB'); \
print('=' * 60); \
print(''); \
print('Available commands:'); \
print('  python training/train_lora.py  --help'); \
print('  python training/train_qwen.py  --help'); \
print('  python -m src.metrics --help'); \
print('  python src/export.py --help'); \
print('  python -m modules.ai.active_learning --help'); \
"]
